{
  "compileOnSave": true,
  "include": ["src"],
  "exclude": [
    "node_modules",
    ".next",
    "functions/**"   // ⬅️ Prevents Next.js from compiling backend Cloud Functions
  ],
  "compilerOptions": {
    "module": "NodeNext",
    "noImplicitReturns": true,
    "outDir": "lib",
    "sourceMap": true,
    "strict": true,
    "target": "es2017",
    "lib": ["es2022"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "moduleResolution": "nodenext",
    "noUnusedLocals": true,
    "types": ["node"],
    "typeRoots": ["./node_modules/@types"]
  }
}
